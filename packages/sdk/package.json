        "email": "niriumprotocol@gmail.com"
    },
    "author": {
        "name": "Nirium Protocol",
        "email": "niriumprotocol@gmail.com",
        "url": "https://nirium.xyz"
    },
    "files": [
        "dist",
        "README.md"
