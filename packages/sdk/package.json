{
    "name": "nirium",
    "version": "0.6.3",
    "description": "Official TypeScript SDK for the Nirium autonomous agent economy on Stellar (x402 + MPP)",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "homepage": "https://nirium.xyz",
    "repository": {
        "type": "git",
