        "dev": "tsc --watch",
        "lint": "eslint src/",
        "test": "jest --passWithNoTests"
    },
    "dependencies": {
        "@stellar/mpp": "^0.4.0",
        "@stellar/stellar-sdk": "^14.5.0",
        "@x402/core": "~2.9.0",
