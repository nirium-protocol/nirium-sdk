        "@x402/stellar": "^2.9.0",
        "mppx": "^0.5.5",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/ws": "^8.18.1",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.11",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "express": "^4.0.0 || ^5.0.0"
